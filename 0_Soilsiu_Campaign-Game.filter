#===============================================================================================================
# Show Item Options
#===============================================================================================================

# Hide all Gear
Hide
Class "Boots" "Gloves" "Helmets" "Body Armours"
Rarity Normal Magic
    SetFontSize 15
    SetBackgroundColor 1 1 1 150

# Hide all Weapons
Hide
Class "Crossbows" "Bows" "Two Hand Maces" "Staves" "Wands" "Shields" "Foci" "One Hand Maces" "Quivers" "Sceptres" "Focus" "Talisman"
Rarity Normal Magic
    SetFontSize 15
    SetBackgroundColor 1 1 1 150
    
#### This is a Hides all
Hide
    Rarity Normal Magic
    SetFontSize 15
    SetBackgroundColor 1 1 1 150