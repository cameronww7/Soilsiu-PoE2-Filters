#===============================================================================================================
# Soilsiu's Campaign Filter - for Path of Exile 2
#===============================================================================================================
# VERSION:  0.5.0
# TYPE:     Early Mapping
# AUTHOR:   Soilsiu
# 
#------------------------------------
# What to Know:
#------------------------------------
# - Being a Soilsiu filter means Green is gonna be showing as GG Items or Key items
# - Smaller Font
#
# - This filter will show almost everything during leveling since we are leveling
#
#------------------------------------
# INSTALLATION:
#------------------------------------
#
# 1) Paste this file into the following folder: %userprofile%/Documents/My Games/Path of Exile
# 2) INGAME: Escape -> Options -> UI -> Scroll down -> Select the filter from the Dropdown box
# 
#===============================================================================================================
# Filter Settings
#===============================================================================================================

#===============================================================================================================
# Overrides
#  This is a section to toss in overrides, such as wanting to always show a certain base
#===============================================================================================================

### End Campaign Base Bows
### Show
### BaseType "Obliterator Bow" "Fanatic Bow"
###     SetFontSize 20
###     MinimapIcon 1 Green Square
###     PlayEffect Green

### End Campaign Base Quivers
### Show
### BaseType "Primed Quiver" "Visceral Quiver"
###     SetFontSize 20
###     MinimapIcon 1 Green Square
###     PlayEffect Green

### Early Campaign Game Base Bows
### Show
### BaseType "Artillery Bow" 
###     SetFontSize 20
###     MinimapIcon 1 Green Square
###     PlayEffect Green

### Early Campaign Game Base Bows
### Show
### BaseType "Dualstring Bow" "Cultist Bow" "Zealot Bow"
###     AreaLevel <= 45
###     SetFontSize 20
###     MinimapIcon 1 Green Square
###     PlayEffect Green

### Early Campaign Game Base Quivers
### Show
### BaseType "Primed Quiver" "Broadhead Quiver"
###     AreaLevel <= 60
###     SetFontSize 20
###     MinimapIcon 1 Green Square
###     PlayEffect Green

#===============================================================================================================
# Exceptional Items For Socket Shards or Quality Shards
#===============================================================================================================

Show
Sockets > 2
    SetFontSize 15
    SetTextColor 90 150 90
    SetBorderColor 90 150 90
    SetBackgroundColor 1 1 1 200

Show
Quality >= 21
    SetFontSize 15
    SetTextColor 90 150 90
    SetBorderColor 90 150 90
    SetBackgroundColor 1 1 1 200

#===============================================================================================================
# Hide Scrolls of Wisdom once you get the Deckard Cain Dood
#===============================================================================================================

Hide
BaseType "Scroll of Wisdom"
AreaLevel >= 50
    SetFontSize 15
    SetTextColor 220 190 132
    SetBorderColor 220 190 132 150
    SetBackgroundColor 1 1 1 150

#===============================================================================================================
# Quest Items
#===============================================================================================================

Show
Class "Instance Local Items" "Quest Items"
    MinimapIcon 1 Grey Square
    SetFontSize 15
    SetBorderColor 0 191 0 200
    SetBackgroundColor 1 1 1 150

#===============================================================================================================
# Gold
#===============================================================================================================

Show
StackSize >= 2500
BaseType "Gold"
	PlayEffect Orange Temp
	MinimapIcon 0 Orange Cross
    SetFontSize 17
	SetTextColor 200 175 0 255
	SetBorderColor 200 175 0 255
    SetBackgroundColor 1 1 1 255

Show
StackSize >= 1000
BaseType "Gold"
	PlayEffect Orange Temp
	MinimapIcon 0 Orange Cross
    SetFontSize 16
	SetTextColor 200 175 0 225
	SetBorderColor 200 175 0 225
    SetBackgroundColor 1 1 1 225   
    
Show
StackSize >= 500
BaseType "Gold"
	PlayEffect Orange Temp
    MinimapIcon 1 Orange Cross
    SetFontSize 15
	SetTextColor 200 175 0 200
	SetBorderColor 200 175 0 200
    SetBackgroundColor 1 1 1 200

Show
StackSize >= 50
BaseType "Gold"
	PlayEffect Orange Temp
    SetFontSize 14
	SetTextColor 200 175 0 200
	SetBorderColor 1 1 1 200
    SetBackgroundColor 1 1 1 200

#### Shows all Gold
Show
BaseType == "Gold"
    SetFontSize 13
	SetTextColor 200 175 0 175
    SetBorderColor 1 1 1 0
    SetBackgroundColor 1 1 1 0

