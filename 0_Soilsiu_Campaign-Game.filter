# Show Pure EV Only Gear
Show
Class "Helmet" "Body Armour" "Glove" "Boots"
Rarity Normal Magic
BaseArmour <= 1
BaseEvasion >= 1
BaseEnergyShield <= 1
 	AreaLevel < 50
    SetFontSize 16
    SetBackgroundColor 1 1 1 150

# Show All Boots & Gloves
Show
Class "Boots" "Gloves"
    PlayEffect Blue
    MinimapIcon 2 Blue Square 
    PlayEffect Blue
    AreaLevel < 40
    SetFontSize 16
    SetBorderColor 0 0 180 250
    SetBackgroundColor 1 1 1 150

#===============================================================================================================
# Salvagable Items For Socket Shards or Quality Shards
#===============================================================================================================

Show
Sockets > 0
Class "Helmets" "Boots" "Gloves" "Wands" "Talismans" "Daggers" "Claws" "Spears" "Bucklers"
Rarity Normal Magic
    SetFontSize 15
    SetTextColor 90 150 90
    SetBorderColor 90 150 90
    SetBackgroundColor 1 1 1 200

Show
Quality >= 1
Class "Helmets" "Boots" "Gloves" "Wands" "Talismans" "Daggers" "Claws" "Spears" "Bucklers"
Rarity Normal Magic
    SetFontSize 15
    SetTextColor 90 150 90
    SetBorderColor 90 150 90
    SetBackgroundColor 1 1 1 200

Show
Class "Life Flasks" "Mana Flasks"
Quality >= 1
    SetFontSize 15
    SetTextColor 90 150 90
    SetBorderColor 90 150 90
    SetBackgroundColor 1 1 1 200

#===============================================================================================================
# Show all First Few Levels
#===============================================================================================================

# Put on Talisman ASAP - At lvl 6 put ponce on
Show
Class "Talisman"
	AreaLevel < 12
    SetFontSize 15
    SetBackgroundColor 1 1 1 150

# Show Everything during the first few levels
Show
	AreaLevel < 9
    SetFontSize 15
    SetBackgroundColor 1 1 1 150

# Show Everything to SELL IF I FUCKING NEED GOLD
Show
Class "Helmets" "Boots" "Gloves" "Wands" "Talismans" "Daggers" "Claws" "Spears" "Bucklers"
Rarity Magic
    SetFontSize 15
    SetBackgroundColor 1 1 1 150

