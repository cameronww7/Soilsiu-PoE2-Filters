# Endgame Base Items
#===============================================================================================================

# Bases I know are Selling well
Show
Rarity Normal
BaseType "Exceptional "
Class "Bow" "Quarterstaff" "Spear" "Wand" "Sceptre"
    PlayAlertSound 3 300
    PlayEffect White
    MinimapIcon 1 White Diamond
    SetFontSize 25
    SetTextColor 200 200 255
    SetBorderColor 200 200 255 250
    SetBackgroundColor 1 1 1 150

