#===============================================================================================================
# Section - Soilsiu's Early Mapping Filter - for Path of Exile 2
#===============================================================================================================
# Section - VERSION:  0.5.0
# TYPE:     Early Mapping
# AUTHOR:   Soilsiu
# 
#------------------------------------
# What to Know:
#------------------------------------
# - Being a Soilsiu filter means Green is gonna be showing as GG Items or Key items
# - Smaller Font
#
# - Early Mapping Hides Normal & Magic Items
#
#------------------------------------
# INSTALLATION:
#------------------------------------
#
# 1) Paste this file into the following folder: %userprofile%/Documents/My Games/Path of Exile
# 2) INGAME: Escape -> Options -> UI -> Scroll down -> Select the filter from the Dropdown box
# 
#===============================================================================================================
# Section - Filter Settings
#===============================================================================================================

#===============================================================================================================
# Section - Overrides
#  This is a section to toss in overrides, such as wanting to always show a certain base
#===============================================================================================================

# End Game Weapons I want
Show
BaseType "Sinister Quarterstaff" "Bladed Quarterstaff" "Bolting Quarterstaff"
UnidentifiedItemTier <= 2
    MinimapIcon 2 Green Square 
    PlayEffect Green
    SetFontSize 20
    SetTextColor 0 200 0
    SetBorderColor 0 200 0 255
    SetBackgroundColor 255 255 255 255

#===============================================================================================================
# Section - Exceptional Items - 3 Socket or 21%+ Quality
#===============================================================================================================

Show
Sockets > 2
    SetFontSize 25
    SetTextColor 90 150 90
    SetBorderColor 90 150 90
    SetBackgroundColor 1 1 1 200

Show
Quality >= 21
    SetFontSize 25
    SetTextColor 0 255 0
    SetBorderColor 0 255 0
    SetBackgroundColor 1 1 1 200

#===============================================================================================================
# Section - Hide Scrolls of Wisdom
#===============================================================================================================

Hide
BaseType "Scroll of Wisdom"
AreaLevel >= 20
    SetFontSize 15
    SetTextColor 220 190 132
    SetBorderColor 220 190 132 150
    SetBackgroundColor 1 1 1 150

#===============================================================================================================
# Section - Quest Items
#===============================================================================================================

Show
Class == "Quest Items"
    PlayAlertSound 2 200
    MinimapIcon 1 Grey Square
    SetFontSize 20
    SetBorderColor 0 191 0 200
    SetBackgroundColor 1 1 1 150

Show
Class == "Instance Local Items"
    PlayAlertSound 2 200
    MinimapIcon 1 Grey Square
    SetFontSize 20
    SetBorderColor 0 191 0 200
    SetBackgroundColor 1 1 1 150

#===============================================================================================================
# Section - Gold
#===============================================================================================================

Show
StackSize >= 5000
BaseType "Gold"
	PlayEffect Orange Temp
	MinimapIcon 0 Orange Cross
    SetFontSize 20
	SetTextColor 200 175 0 255
	SetBorderColor 200 175 0 255
    SetBackgroundColor 1 1 1 255

Show
StackSize >= 2500
BaseType "Gold"
	PlayEffect Orange Temp
	MinimapIcon 0 Orange Cross
    SetFontSize 19
	SetTextColor 200 175 0 255
	SetBorderColor 200 175 0 255
    SetBackgroundColor 1 1 1 255
    
Show
StackSize >= 1000
BaseType "Gold"
	PlayEffect Orange Temp
    MinimapIcon 1 Orange Cross
    SetFontSize 18
	SetTextColor 200 175 0 225
	SetBorderColor 200 175 0 225
    SetBackgroundColor 1 1 1 200

Show
StackSize >= 500
BaseType "Gold"
	PlayEffect Orange Temp
    SetFontSize 17
	SetTextColor 200 175 0 225
	SetBorderColor 200 175 0 225
    SetBackgroundColor 1 1 1 200

#### Shows all Gold
Show
BaseType == "Gold"
    SetFontSize 14
	SetTextColor 200 175 0 175
    SetBorderColor 1 1 1 0
    SetBackgroundColor 1 1 1 0

#===============================================================================================================
# Section - Exotic Bases
#===============================================================================================================

Show # Showing Super Exotic Bases
	Rarity Normal Magic Rare
	BaseType == "Aberrant Sledge" "Abyssal Signet" "Ancient Gauntlets" "Ancient Leggings" "Ancient Mail" "Ancient Visor" "Diamond" "Glacial Fortress" "Heartwood Shortbow" "Ornate Ringmail" "Pearlescent Amulet" "Perching Staff" "Primal Markings" "Reflecting Staff" "Runic Fork" "Sacrificial Regalia" "Tenebrous Crown" "Time-Lost Diamond" "Twisted Wand" "Two-Stone Ring" "Venerable Defender" "Veridical Chain" "Warding Quarterstaff"
